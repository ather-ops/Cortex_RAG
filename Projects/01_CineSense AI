# step 6: Create a combined data
df["combined_txt"]=(df["title"]+" "+ df["director"].fillna('')+" "+df["cast"].fillna('')+" "+df["listed_in"]+" "+df["description"])

# step 7: Model selection and embeddings
model=SentenceTransformer("all-MiniLM-L6-v2")
try:
    print("Generating embeddings. This may take a few minutes...")
    embeddings=model.encode(df["combined_txt"].tolist(), show_progress_bar=True)
    print("Embeddings generated successfully!")
except KeyboardInterrupt:
    print("\nProcess interrupted by user. Taking a smaller sample...")
    # Use a smaller sample of the data (first 100 rows)
    sample_df = df.head(100)
    embeddings=model.encode(sample_df["combined_txt"].tolist(), show_progress_bar=True)
    df = sample_df
    print(f"Continuing with {len(df)} items instead")
except Exception as e:
    print(f"Error generating embeddings: {e}")
    exit()
print("=="*40)

# step 8: Initialise chromadb
client=chromadb.Client()
print("Client Created successfully")
print("=="*40)

# step 9: Creating collections
# always delete existing collection for clean start
try:
    client.delete_collection("netflix_titles")
    print("Deleted existing collection successfully")
except:
    print("No existing collection found!")

# creating new collection
collection=client.create_collection(
    name="netflix_titles",
    metadata={
       "description":"netflix movies and Tv shows",
       "total_items":len(df),
       "total_columns":len(df.columns),
       "embedding_model":"all-MiniLM-L6-v2"
    }
)

print("Collection created successfully:",collection.name)
print("Initial count :",collection.count())
